# API (apps/api)
# Encode @ as %40 and # as %23 in the password
# Use Session pooler URI from Supabase Dashboard (IPv4-friendly). Example:
# DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-ap-south-1.pooler.supabase.com:5432/postgres?sslmode=require&connect_timeout=10"
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres?sslmode=require&connect_timeout=10"
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="24h"
CORS_ORIGIN="http://localhost:3000"
PORT=4000
SEED_EMAIL="owner@skmobile.local"
SEED_PASSWORD="Shaikh@123"

