# API (apps/api)
# IMPORTANT: For local development, do NOT use your production Render/Supabase database URL here.
# Use a local Postgres URL (or a dedicated dev DB) so your live application data cannot be modified.
DATABASE_URL="postgresql://postgres:password@localhost:5432/sk_mobile"
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="24h"
CORS_ORIGIN="http://localhost:3000"
PORT=4000

# Web (apps/web)
NEXT_PUBLIC_API_URL="http://localhost:4000"

# Default owner login is seeded in apps/api/prisma/seed.ts (not from env)
