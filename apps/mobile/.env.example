# Local API (simulator/emulator)
EXPO_PUBLIC_API_URL=http://localhost:4000

# Physical device on same Wi‑Fi — use your machine LAN IP, e.g.:
# EXPO_PUBLIC_API_URL=http://192.168.1.42:4000

# Production (EAS preview/production builds use eas.json env; override here for local prod testing)
# EXPO_PUBLIC_API_URL=https://sk-mobile-api.onrender.com

# EAS Build (run from apps/mobile):
#   npx eas login
#   npx eas build:configure   # first time — links EAS project
#   npm run build:preview       # Android APK + iOS internal
#   npm run build:production    # store-ready builds
