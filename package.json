{
  "name": "sk-mobile",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@sk-mobile/api & npm run dev --workspace=@sk-mobile/web",
    "dev:api": "npm run dev --workspace=@sk-mobile/api",
    "dev:web": "npm run dev --workspace=@sk-mobile/web",
    "dev:mobile": "npm run start --workspace=@sk-mobile/mobile",
    "dev:flutter": "powershell -ExecutionPolicy Bypass -File scripts/run-flutter.ps1",
    "dev:flutter:phone": "powershell -ExecutionPolicy Bypass -File scripts/run-flutter-phone.ps1",
    "install:flutter:phone": "powershell -ExecutionPolicy Bypass -File scripts/install-flutter-phone.ps1",
    "build:flutter:apk": "powershell -ExecutionPolicy Bypass -File scripts/build-flutter-apk.ps1",
    "build:mobile:preview": "npm run build:preview --workspace=@sk-mobile/mobile",
    "build:mobile:production": "npm run build:production --workspace=@sk-mobile/mobile",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspace=@sk-mobile/api",
    "db:generate": "npm run db:generate --workspace=@sk-mobile/api",
    "db:migrate": "npm run db:migrate --workspace=@sk-mobile/api",
    "db:seed": "npm run db:seed --workspace=@sk-mobile/api",
    "db:reset-data": "npm run db:reset-data --workspace=@sk-mobile/api",
    "db:push": "npm run db:push --workspace=@sk-mobile/api",
    "build:deploy": "npm run build --workspace=@sk-mobile/shared && npm run build --workspace=@sk-mobile/api && npm run build --workspace=@sk-mobile/web",
    "build:firebase": "node scripts/build-firebase.mjs",
    "build:apk": "node scripts/build-android-apk.mjs",
    "build:apk:local": "node scripts/build-android-apk-local.mjs"
  },
  "engines": {
    "node": ">=20"
  }
}
